# Backend Configuration
DATABASE_URL=sqlite:///./data/mes.db

# SQL Server Configuration (for central database sync)
SQL_SERVER_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=your_server;Database=mes_db;UID=username;PWD=password

# ERP API Configuration
ERP_API_URL=https://your-erp-system.com/api
ERP_API_KEY=your-erp-api-key

# Sync Configuration
SYNC_INTERVAL_MINUTES=20

# Device Configuration
PLC_HOST=localhost
PLC_PORT=502
RFID_SERIAL_PORT=/dev/ttyUSB0
BARCODE_SERIAL_PORT=/dev/ttyUSB1

# Security
SECRET_KEY=your-secret-key-change-in-production